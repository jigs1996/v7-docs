{
  "name": "v7-new-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build && node ace build:static",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#collections/*": "./app/collections/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0-next.19",
    "@adonisjs/eslint-config": "^3.0.0-next.4",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0-next.3",
    "@alpinejs/collapse": "^3.15.2",
    "@japa/assert": "^4.1.1",
    "@japa/plugin-adonisjs": "^5.0.0-next.0",
    "@japa/runner": "^4.4.0",
    "@poppinss/ts-exec": "^1.4.1",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^24.10.1",
    "alpinejs": "^3.15.2",
    "eslint": "^9.39.1",
    "hot-hook": "^0.4.1-next.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "typescript": "~5.9",
    "unpoly": "^3.12.0",
    "vite": "^7.2.6",
    "youch": "^4.1.0-beta.11"
  },
  "dependencies": {
    "@adonisjs/content": "^1.3.0",
    "@adonisjs/core": "^7.0.0-next.12",
    "@adonisjs/static": "^2.0.0-next.1",
    "@adonisjs/vite": "^5.1.0-next.2",
    "@github/tab-container-element": "^4.8.2",
    "@iconify-json/mynaui": "^1.2.16",
    "@iconify-json/tabler": "^1.2.23",
    "@iconify-json/uiw": "^1.2.3",
    "@tailwindcss/vite": "^4.1.17",
    "@types/luxon": "^3.7.1",
    "@vinejs/vine": "^4.1.0",
    "edge-iconify": "^2.0.1",
    "edge-markdown": "^1.7.0",
    "edge.js": "^6.3.0",
    "hast-util-to-text": "^4.0.2",
    "luxon": "^3.7.2",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
