<div class="relative hidden sm:block" x-data="{ open: false }">
    <button @click="open = !open" class="group relative flex gap-1.5 border border-woodsmoke-800/60 bg-woodsmoke-900/38 backdrop-blur-xl pl-3 py-2 pr-8 rounded-md text-woodsmoke-400 hover:text-woodsmoke-300 transition-colors">
        @svg('mynaui:cog', {class: 'w-5 h-5'})
        <span class="text-13 font-medium">Actions</span>
        <span>
            @svg('mynaui:chevron-down', { class: 'absolute w-5 h-5 text-woodsmoke-400 right-2 transition-transform', 'x-bind:class': "{\'rotate-180\': open}" })
        </span>
    </button>
    <div x-show="open" @click.outside="open=false" class="absolute right-0 border border-woodsmoke-800/60 bg-woodsmoke-950/38 backdrop-blur-md px-4 py-2.5 rounded-md text-13 w-44 mt-0.5">
        <div class="group">
            <button class="py-1.5 rounded-md w-full text-left flex items-center gap-1.5 hover:text-woodsmoke-50 transition-colors">
                @svg('mynaui:copy', {class: 'w-4 h-4 '}) 
                Copy as markdown
            </button>
        </div>
        <div class="group">
            <button class="py-1.5 rounded-md w-full text-left flex items-center gap-1.5 hover:text-woodsmoke-50 transition-colors">
                @svg('mynaui:indifferent-square', {class: 'w-4 h-4'}) 
                Copy as LLM .TXT
            </button>
        </div>
        <div class="group">
            <a 
                href="" 
                class="py-1.5 rounded-md w-full text-left flex items-center gap-1.5 text-woodsmoke-300! hover:text-woodsmoke-50! transition-colors" 
                target="_blank">
                @svg('mynaui:edit-one', {class: 'w-4 h-4'})
                Edit on Github
            </a>
        </div>
    </div>
</div>